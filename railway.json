{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["backend/**", "frontend/**"],
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPackages": ["nodejs_20"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node start.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
