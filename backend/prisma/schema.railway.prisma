generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id            String              @id @default(uuid())
  name          String              @unique
  slug          String              @unique
  active        Boolean             @default(true)
  address       String?
  phone         String?
  contactEmail  String?
  users         User[]
  patients      Patient[]
  subscription  ClinicSubscription?
  loginLogs     LoginLog[]
  paymentReceipts PaymentReceipt[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model ClinicSubscription {
  id          String   @id @default(uuid())
  clinicId    String   @unique
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  plan        String   @default("MONTHLY")
  amount      Float    @default(100)
  startDate   DateTime @default(now())
  nextBilling DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoginLog {
  id        String   @id @default(uuid())
  username  String
  clinicId  String?
  clinic    Clinic?  @relation(fields: [clinicId], references: [id])
  success   Boolean
  ip        String?
  createdAt DateTime @default(now())
}

model PaymentReceipt {
  id          String   @id @default(uuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  amount      Float
  method      String   @default("TRANSFER")
  reference   String?
  status      String   @default("PENDING")
  receiptUrl  String?
  notes       String?
  periodStart DateTime?
  periodEnd   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  username     String        @unique
  password     String
  role         String        @default("ORTHODONTIST")
  active       Boolean       @default(true)
  clinicId     String?
  clinic       Clinic?       @relation(fields: [clinicId], references: [id])
  patients     Patient[]     @relation("ResponsibleOrthodontist")
  appointments Appointment[] @relation("OrthodontistAppointments")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ToothRecord {
  id        String   @id @default(uuid())
  number    Int
  face      String   @default("vestibular")
  status    String   @default("HEALTHY")
  notes     String?
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
  updatedAt DateTime @updatedAt

  @@unique([patientId, number, face])
}

model Patient {
  id              String        @id @default(uuid())
  firstName       String
  lastName        String
  birthDate       DateTime
  phone           String
  email           String?
  address         String?
  clinicalHistory String?
  orthodontistId  String
  orthodontist    User          @relation("ResponsibleOrthodontist", fields: [orthodontistId], references: [id])
  appointments    Appointment[]
  treatments      Treatment[]
  payments        Payment[]
  toothRecords    ToothRecord[]
  clinicId        String
  clinic          Clinic        @relation(fields: [clinicId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Appointment {
  id             String     @id @default(uuid())
  date           DateTime
  duration       Int        @default(30)
  type           String
  status         String     @default("SCHEDULED")
  patientId      String
  patient        Patient    @relation(fields: [patientId], references: [id])
  orthodontistId String
  orthodontist   User       @relation("OrthodontistAppointments", fields: [orthodontistId], references: [id])
  evolution      Evolution?
  payments       Payment[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Treatment {
  id              String        @id @default(uuid())
  type            String
  startDate       DateTime      @default(now())
  estimatedMonths Int
  active          Boolean       @default(true)
  totalCost       Float?
  phases          String?
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  evolutions      Evolution[]
  payments        Payment[]
  inventoryUsage  InventoryUsage[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Evolution {
  id            String      @id @default(uuid())
  date          DateTime    @default(now())
  observations  String
  photoBefore   String?
  photoAfter    String?
  treatmentId   String
  treatment     Treatment   @relation(fields: [treatmentId], references: [id])
  appointmentId String?     @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

model Payment {
  id            String      @id @default(uuid())
  amount        Float
  method        String
  date          DateTime    @default(now())
  note          String?
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  treatmentId   String
  treatment     Treatment   @relation(fields: [treatmentId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

model InventoryItem {
  id        String           @id @default(uuid())
  name      String
  category  String
  stock     Int              @default(0)
  minStock  Int              @default(10)
  usages    InventoryUsage[]
  updatedAt DateTime         @updatedAt
}

model InventoryUsage {
  id          String        @id @default(uuid())
  quantity    Int
  date        DateTime      @default(now())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  treatmentId String
  treatment   Treatment     @relation(fields: [treatmentId], references: [id])
}
